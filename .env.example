# Formspree (Plan B — quick launch, no backend needed)
# Sign up at formspree.io → create a form → paste the form ID here
FORMSPREE_ID=

# Supabase (Plan A — full backend, activate after Formspree is live)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=

# Anthropic (Benny AI — Month 1)
# ANTHROPIC_API_KEY=

# Email (Resend — Month 1)
# RESEND_API_KEY=
# FROM_EMAIL=flat@flatfinder.io

# Stripe (Month 3)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# App
APP_URL=https://flatfinder.io
